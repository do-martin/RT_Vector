FROM node:22-alpine

WORKDIR /app

# Install exact versions from lock file and clean the cache afterwards.
# node_modules stays in the image layer; docker-compose overlays it with a
# named volume so the bind-mount ./frontend:/app does not shadow it.
COPY package.json package-lock.json ./
RUN npm ci && npm cache clean --force

ENV NODE_ENV=development \
    NEXT_TELEMETRY_DISABLED=1 \
    WATCHPACK_POLLING=true \
    CHOKIDAR_USEPOLLING=true

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0"]
