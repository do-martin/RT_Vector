FROM python:3.12-slim

# Python: no .pyc files, unbuffered stdout/stderr for clean container logs
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# System dependencies needed at runtime:
#   libgl1       — libGL.so.1 required by cv2 (OpenCV), imported by
#                  docling-ibm-models for table structure detection
#   libglib2.0-0 — glib runtime also needed by OpenCV
#   poppler-utils — PDF info / image extraction used by Docling
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Copy uv binary from the official minimal image
COPY --from=ghcr.io/astral-sh/uv:0.6.14 /uv /uvx /usr/local/bin/

WORKDIR /app

# Install Python dependencies into /opt/venv — deliberately outside /app so
# the bind-mount (./backend:/app) used for hot-reload does not shadow them.
COPY pyproject.toml uv.lock ./
RUN UV_PROJECT_ENVIRONMENT=/opt/venv uv sync --frozen --no-cache

ENV PATH="/opt/venv/bin:$PATH"

EXPOSE 8000

# uvicorn --reload watches /app for source changes (served via bind mount)
CMD ["uvicorn", "main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]
